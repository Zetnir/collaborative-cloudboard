# ============================================
# GLOBAL IGNORE (applies to root, client, server)
# ============================================

# Environment variables
.env
.env.*
*.env
*.env.*

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
logs
*.log

# OS files
.DS_Store
Thumbs.db

# Editor folders
.vscode/
.idea/
*.swp

# Node modules (root or nested)
node_modules/

# ============================================
# FRONTEND (React + Vite)
# ============================================

# Vite build output
dist/
dist-ssr/
*.local

# Vite cache
.vite/

# React build output (if using CRA somewhere)
build/

# TypeScript
*.tsbuildinfo

# ============================================
# BACKEND (Node.js / Express / TS)
# ============================================

# Build output
server/dist/
server/build/
backend/dist/
backend/build/

# TypeScript
server/*.tsbuildinfo
backend/*.tsbuildinfo

# PM2 logs
.pids
*.pid
*.seed
*.pid.lock

# Coverage
coverage/

# Local database files
*.sqlite
*.db
*.db-journal

# ============================================
# OPTIONAL: Docker
# ============================================

docker-data/
docker-compose.override.yml

# ============================================
# OPTIONAL: Testing
# ============================================

coverage/
.nyc_output/
jest-cache/
jest-html-reporters-*

# ============================================
# OPTIONAL: Agents
# ============================================

.github/agents/

package-lock.json